{
  "buildCommand": "cd hanain && npm install && npm run build && mkdir -p ../public && cp dist/index.html ../public/index.html",
  "outputDirectory": "hanain/dist",
  "functions": {
    "api/seo.js": {
      "includeFiles": "public/**"
    }
  },
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/", "destination": "/api/seo?p=/" },
    { "source": "/home", "destination": "/api/seo?p=/home" },
    { "source": "/easy", "destination": "/api/seo?p=/easy" },
    { "source": "/phlorotannin", "destination": "/api/seo?p=/phlorotannin" },
    { "source": "/learn", "destination": "/api/seo?p=/learn" },
    { "source": "/qa", "destination": "/api/seo?p=/qa" },
    { "source": "/blog", "has": [{ "type": "query", "key": "category", "value": "ingredient-comparison" }], "destination": "/api/seo?p=/blog%3Fcategory%3Dingredient-comparison" },
    { "source": "/blog", "has": [{ "type": "query", "key": "category", "value": "disease-health-info" }], "destination": "/api/seo?p=/blog%3Fcategory%3Ddisease-health-info" },
    { "source": "/blog", "has": [{ "type": "query", "key": "category", "value": "hospital-info" }], "destination": "/api/seo?p=/blog%3Fcategory%3Dhospital-info" },
    { "source": "/blog", "has": [{ "type": "query", "key": "category", "value": "partner-info" }], "destination": "/api/seo?p=/blog%3Fcategory%3Dpartner-info" },
    { "source": "/blog", "destination": "/api/seo?p=/blog" },
    { "source": "/blog/:slug", "destination": "/api/seo?p=/blog/:slug" },
    { "source": "/community", "destination": "/api/seo?p=/community" },
    { "source": "/consult", "destination": "/api/seo?p=/consult" },
    { "source": "/partner", "destination": "/api/seo?p=/partner" },
    { "source": "/copyright", "destination": "/api/seo?p=/copyright" },
    { "source": "/category/:slug", "destination": "/api/seo?p=/category/:slug" },
    { "source": "/p/:phone", "destination": "/api/seo?p=/p/:phone" },
    { "source": "/(.*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/qa.json",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=3600" }]
    },
    {
      "source": "/assets/(.*)",
      "headers": [{ "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }]
    }
  ]
}
