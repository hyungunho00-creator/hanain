# ======================================================
# 플로로탄닌 파트너스 - 환경변수 설정 예시
# ======================================================
# 이 파일을 복사해서 .env.local 로 저장 후 값을 채우세요.
# .env.local 은 절대 GitHub에 올리지 마세요! (.gitignore 에 포함됨)

# [Formspree] 상담 폼 → 이메일 수신
# https://formspree.io 가입 → 새 폼 생성 → Form ID 복사
VITE_FORMSPREE_ID=여기에_Formspree_Form_ID_입력

# [Formspree] 파트너 신청 폼 (상담과 다른 폼 ID 사용 가능)
VITE_FORMSPREE_PARTNER_ID=여기에_파트너용_Formspree_Form_ID_입력

# [관리자 페이지] /admin 접속 비밀번호
# 반드시 영문+숫자 조합 8자리 이상으로 변경하세요
VITE_ADMIN_PASS=강력한비밀번호로변경

# [선택사항] 백엔드 서버 URL (별도 서버 운영 시에만 필요)
# VITE_BACKEND_URL=https://your-backend.com
